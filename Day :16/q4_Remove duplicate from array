#include <stdio.h>

int removeDuplicates(int arr[], int size) {
    if (size == 0 || size == 1) return size;
    
    int unique_index = 0;
    
    for (int i = 0; i < size; i++) {
        int is_duplicate = 0;
        
        // Check if the element already exists in the unique part
        for (int j = 0; j < unique_index; j++) {
            if (arr[i] == arr[j]) {
                is_duplicate = 1;
                break;
            }
        }
        
        // If it's a new element, move it to the front
        if (!is_duplicate) {
            arr[unique_index] = arr[i];
            unique_index++;
        }
    }
    
    return unique_index; // Returns new length of the array
}

int main() {
    int arr[] = {1, 2, 2, 3, 4, 4, 5, 1};
    int size = sizeof(arr) / sizeof(arr[0]);
    
    int new_size = removeDuplicates(arr, size);
    
    printf("Array after removing duplicates: ");
    for (int i = 0; i < new_size; i++) {
        printf("%d ", arr[i]);
    }
    printf("\n");
    
    return 0;
}
