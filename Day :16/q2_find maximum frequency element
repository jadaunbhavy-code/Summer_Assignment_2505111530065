#include <stdio.h>

#include <stdio.h>

int findMaxFrequencyElement(int arr[], int size) {
    // Assuming array elements are positive and less than 1000
    int freq[1000] = {0}; 
    
    // Count frequencies
    for (int i = 0; i < size; i++) {
        freq[arr[i]]++;
    }
    
    int max_freq = 0;
    int max_element = arr[0];
    
    // Find the element with the maximum frequency
    for (int i = 0; i < size; i++) {
        if (freq[arr[i]] > max_freq) {
            max_freq = freq[arr[i]];
            max_element = arr[i];
        }
    }
    
    return max_element;
}

int main() {
    int arr[] = {1, 3, 2, 3, 4, 3, 2, 1};
    int size = sizeof(arr) / sizeof(arr[0]);
    
    printf("Maximum Frequency Element: %d\n", findMaxFrequencyElement(arr, size));
    
    return 0;
}
