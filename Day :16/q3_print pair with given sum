#include <stdio.h>

void findPairWithSum(int arr[], int size, int target) {
    // Lookup array to store visited elements (handles values up to 1000)
    int visited[1000] = {0};
    
    for (int i = 0; i < size; i++) {
        int complement = target - arr[i];
        
        // Check if the complement has already been seen
        if (complement >= 0 && visited[complement] == 1) {
            printf("Pair found: (%d, %d)\n", complement, arr[i]);
            return;
        }
        
        // Mark current element as visited
        if (arr[i] >= 0) {
            visited[arr[i]] = 1;
        }
    }
    
    printf("No pair found with the given sum.\n");
}

int main() {
    int arr[] = {10, 15, 3, 7};
    int target = 17;
    int size = sizeof(arr) / sizeof(arr[0]);
    
    findPairWithSum(arr, size, target);
    
    return 0;
}
