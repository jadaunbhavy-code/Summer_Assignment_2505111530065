#include <stdio.h>

int main() {
    int arr[] = {12, 5, 7, 25, 3}, n = 5;
    int max = arr[0], min = arr[0];
    
    for (int i = 1; i < n; i++) {
        if (arr[i] > max) max = arr[i];
        if (arr[i] < min) min = arr[i];
    }
    printf("Largest: %d, Smallest: %d\n", max, min);
    return 0;
}
