#include <stdio.h>

int linearSearch(int arr[], int n, int key) {
    for (int i = 0; i < n; i++) {
        if (arr[i] == key) return i;
    }
    return -1;
}

int main() {
    int arr[] = {10, 20, 30, 40}, n = 4, key = 30;
    int index = linearSearch(arr, n, key);
    if(index != -1) printf("Found at index %d\n", index);
    else printf("Not found\n");
    return 0;
}
