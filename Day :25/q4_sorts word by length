#include <stdio.h>
#include <string.h>

int main() {
    char words[3][20] = {"Capgemini", "Amazon", "Deloitte"}, temp[20];
    int n = 3;
    for (int i = 0; i < n - 1; i++) {
        for (int j = i + 1; j < n; j++) {
            if (strlen(words[i]) > strlen(words[j])) {
                strcpy(temp, words[i]);
                strcpy(words[i], words[j]);
                strcpy(words[j], temp);
            }
        }
    }
    printf("Sorted by length:\n");
    for (int i = 0; i < n; i++) printf("%s\n", words[i]);
    return 0;
}
