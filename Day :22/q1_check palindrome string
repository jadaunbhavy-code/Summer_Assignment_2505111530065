#include <stdio.h>
int main() {
    char str[] = "radar";
    int len = 0, pal = 1;
    while(str[len] != '\0') len++;
    for(int i = 0; i < len/2; i++) {
        if(str[i] != str[len - 1 - i]) { pal = 0; break; }
    }
    if(pal) printf("Palindrome");
    else printf("Not Palindrome");
    return 0;
}
