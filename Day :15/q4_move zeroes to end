#include <stdio.h>

int main() {
    int arr[] = {1, 0, 2, 0, 3, 4}, n = 6, count = 0;
    
    for (int i = 0; i < n; i++) {
        if (arr[i] != 0) {
            arr[count++] = arr[i];
        }
    }
    while (count < n) arr[count++] = 0;
    
    printf("Result: ");
    for (int i = 0; i < n; i++) printf("%d ", arr[i]);
    return 0;
}
