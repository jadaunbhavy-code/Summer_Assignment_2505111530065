#include <stdio.h>
int main() {
    char str[] = "test sample";
    int freq[256] = {0}, max = 0;
    char maxCh;
    for(int i = 0; str[i] != '\0'; i++) {
        if(str[i] != ' ') {
            freq[(unsigned char)str[i]]++;
            if(freq[(unsigned char)str[i]] > max) {
                max = freq[(unsigned char)str[i]];
                maxCh = str[i];
            }
        }
    }
    printf("Max occurring character: %c", maxCh);
    return 0;
}
