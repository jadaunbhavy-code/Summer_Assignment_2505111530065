#include <stdio.h>
#include <string.h>

int main() {
    char str1[] = "microsoft", str2[] = "adobe";
    int count1[26] = {0}, count2[26] = {0};
    
    for (int i = 0; str1[i] != '\0'; i++) count1[str1[i] - 'a']++;
    for (int i = 0; str2[i] != '\0'; i++) count2[str2[i] - 'a']++;
    
    printf("Common characters: ");
    for (int i = 0; i < 26; i++) {
        if (count1[i] > 0 && count2[i] > 0) {
            printf("%c ", i + 'a');
        }
    }
    return 0;
}
