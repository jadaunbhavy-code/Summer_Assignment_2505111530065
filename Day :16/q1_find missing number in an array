#include <stdio.h>

int findMissingNumber(int arr[], int n) {
    // Calculate expected sum of first n natural numbers
    int expected_sum = (n * (n + 1)) / 2;
    int actual_sum = 0;
    
    // Calculate the sum of elements present in the array
    for (int i = 0; i < n - 1; i++) {
        actual_sum += arr[i];
    }
    
    return expected_sum - actual_sum;
}

int main() {
    // Array of size 4 containing numbers from 1 to 5 (4 is missing)
    int arr[] = {1, 2, 3, 5};
    int n = 5; // The range of numbers is 1 to 5
    
    int missing = findMissingNumber(arr, n);
    printf("Missing Number: %d\n", missing);
    
    return 0;
}
