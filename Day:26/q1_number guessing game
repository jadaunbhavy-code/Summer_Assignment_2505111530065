#include <stdio.h>

int main() {
    int secret = 42, guess;
    printf("Guess the secret number (1-100): ");
    do {
        scanf("%d", &guess);
        if (guess > secret) printf("Too high! Try again: ");
        else if (guess < secret) printf("Too low! Try again: ");
    } while (guess != secret);
    printf("Congratulations! You guessed it.\n");
    return 0;
}
